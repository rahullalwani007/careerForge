# ─────────────────────────────────────────────────────────────
#  CareerForge AI — Backend Environment Variables
#  Copy this file to .env and fill in your keys.
#  NEVER commit .env to git (it already is git-ignored).
# ─────────────────────────────────────────────────────────────

PORT=5000

# ── JWT ──────────────────────────────────────────────────────
# Any long random string. Used to sign login tokens.
JWT_SECRET=change-this-to-a-long-random-string

# ── GROQ API (FREE) ──────────────────────────────────────────
# Get your free key at: https://console.groq.com
# Without a key, the app still works end-to-end using curated
# fallback content — good for a demo with zero setup, but a real
# key is what makes questions/feedback genuinely AI-generated.
GROQ_API_KEY=your_groq_api_key_here

# Models — Groq deprecated llama-3.1-8b-instant in June 2026.
# These are the current free-tier models Groq recommends instead.
# GROQ_MODEL_FAST is used for latency-sensitive calls (per-answer
# feedback, chat, next-question). GROQ_MODEL_QUALITY is used for
# the few calls where quality matters more than speed (career path,
# resume analysis, final report).
GROQ_MODEL_FAST=openai/gpt-oss-20b
GROQ_MODEL_QUALITY=openai/gpt-oss-120b
# low | medium | high — low is fastest and is enough for the
# structured-JSON tasks this app asks for.
GROQ_REASONING_EFFORT=low

# ── YOUTUBE DATA API v3 (FREE, Google Cloud) ─────────────────
# 1. Go to: https://console.cloud.google.com
# 2. Create a project → Enable "YouTube Data API v3"
# 3. Create Credentials → API Key
# Free quota: 10,000 units/day. The backend caches search results
# (see src/services/youtubeService.js) so this quota goes a long way.
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CACHE_TTL_HOURS=12

# ── Database ──────────────────────────────────────────────────
# Leave unset to use the default: backend/data/careerforge.db
# DB_PATH=./data/careerforge.db

# Set to "false" to disable the automatic demo-data seed on first boot.
AUTO_SEED=true
